<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>SINGING REGISTRATION - WALLA / HEESAY</title>

<style>
body{
  background:black;
  color:white;
  font-family:Poppins, sans-serif;
  padding:40px;
  line-height:1.6;
}

h1,h2{
  color:gold;
  text-align:center;
}

.container{
  max-width:900px;
  margin:auto;
  background:#111;
  padding:40px;
  border-radius:15px;
  border:2px solid gold;
  box-shadow:0 0 30px rgba(255,215,0,0.4);
}

.description{
  background:#000;
  border:1px solid gold;
  padding:20px;
  border-radius:10px;
  margin-bottom:20px;
  color:gold;
  font-weight:bold;
  text-align:center;
}

.rules-button{
  display:block;
  text-align:center;
  padding:12px;
  background:transparent;
  border:1px solid gold;
  color:gold;
  border-radius:30px;
  text-decoration:none;
  margin-bottom:30px;
  transition:0.3s;
}

.rules-button:hover{
  background:gold;
  color:black;
}

.translate-btn{
  display:block;
  width:200px;
  margin:0 auto 25px auto;
  padding:10px;
  border-radius:30px;
  border:1px solid gold;
  background:transparent;
  color:gold;
  cursor:pointer;
  font-weight:bold;
}

input, select{
  width:100%;
  padding:12px;
  margin-top:10px;
  margin-bottom:20px;
  border-radius:8px;
  border:1px solid gold;
  background:black;
  color:white;
}

label{
  font-weight:bold;
  color:gold;
}

.checkbox-area{
  margin:20px 0;
  background:#000;
  padding:15px;
  border-radius:10px;
  border:1px solid gold;
}

.checkbox-area input{
  width:auto;
  margin-right:10px;
}

.button-wa{
  display:inline-block;
  padding:14px 30px;
  background:linear-gradient(90deg,gold,orange);
  color:black;
  font-weight:bold;
  border-radius:40px;
  border:none;
  cursor:pointer;
  transition:0.3s;
  width:100%;
}

.button-wa:hover{
  transform:scale(1.05);
}

.footer{
  margin-top:40px;
  text-align:center;
  color:gold;
  font-weight:bold;
}
</style>
</head>

<body>
<div class="container">

<h1>🎤 SINGING REGISTRATION</h1>
<h2>CHASTE DRAGON SQUAD</h2>
<h2>WALLA / HEESAY DIVISION</h2>

<button class="translate-btn" onclick="toggleLang()" id="btnTranslate">
🌐 Translate: ID
</button>

<hr style="border:1px solid gold;margin:30px 0;">

<div class="description" id="descText">
MOHON MEMBACA DAN MEMAHAMI SELURUH PERATURAN SEBELUM MENDAFTAR.
Dengan mendaftar berarti Anda siap mengikuti event singing di Walla / Heesay.
</div>

<a href="sing-walla-heesay-rules.html" class="rules-button" id="rulesBtn">
📜 BACA PERATURAN
</a>

<form id="formWalla">

<label id="lblAdmin">Pilih Admin</label>
<select id="admin" required>
<option value="">-- Select Admin --</option>
<option value="6285191295022">Admin Jessica</option>
<option value="6288291996193">Admin Panda</option>
<option value="6282246142678">Admin Surya</option>
<option value="6283126442689">Admin Rara</option>
</select>

<label id="lblNama">Full Name</label>
<input type="text" id="nama" required>

<label id="lblUmur">Age</label>
<input type="number" id="umur" required>

<label id="lblAsal">From</label>
<input type="text" id="asal" required>

<label id="lblGroup">Name Group Sing</label>
<input type="text" id="groupname" required>

<label id="lblJumlah">How many people are there in the group?</label>
<input type="number" id="jumlah" required>

<label id="lblMember">Name Member Group</label>
<input type="text" id="membergroup" required>

<label id="lblLagu">What song will you sing?</label>
<input type="text" id="lagu" required>

<label id="lblLink">Link Account Walla-Heesay</label>
<input type="text" id="link" required>

<label id="lblLinkGroup">
Link Group Sing  
<span id="infoGroup" style="font-size:12px;color:#ccc;">
(information: Your Group Sing, if don't have make sure to create and make group sing)
</span>
</label>
<input type="text" id="linkgroup" required>

<div class="checkbox-area">
<input type="checkbox" id="setuju">
<label for="setuju" id="lblAgree">
Saya menyatakan sudah membaca dan menyetujui seluruh peraturan.
</label>
</div>

<button type="submit" class="button-wa" id="btnSubmit">
KIRIM PENDAFTARAN VIA WHATSAPP
</button>

</form>

<div class="footer">
OFFICIAL SINGING REGISTRATION 2026<br>
© CHASTE DRAGON
</div>

</div>

<script>
const langs = ["id","en","cn","ph","kr"];
let indexLang = 0;

function toggleLang(){
  indexLang = (indexLang + 1) % langs.length;
  const lang = langs[indexLang];
  const btn = document.getElementById("btnTranslate");

  if(lang==="id"){
    btn.innerText="🌐 Translate: ID";
    descText.innerText="MOHON MEMBACA DAN MEMAHAMI SELURUH PERATURAN SEBELUM MENDAFTAR. Dengan mendaftar berarti Anda siap mengikuti event singing di Walla / Heesay.";
    rulesBtn.innerText="📜 BACA PERATURAN";
    lblAdmin.innerText="Pilih Admin";
    lblNama.innerText="Nama Lengkap Peserta";
    lblUmur.innerText="Umur Para Peserta";
    lblAsal.innerText="Asal Kota";
    lblGroup.innerText="Nama Group";
    lblJumlah.innerText="Ada berapa orang dalam group?";
    lblMember.innerText="Nama Anggota Grup";
    lblLagu.innerText="Lagu apa yang akan kamu nyanyikan?";
    lblLink.innerText="Link akun Walla-Heesay";
    infoGroup.innerText="(informasi: jika kamu belum memilikinya, silakan buat grup)";
    lblAgree.innerText="Saya menyatakan sudah membaca dan menyetujui seluruh peraturan.";
    btnSubmit.innerText="KIRIM PENDAFTARAN VIA WHATSAPP";
  }

  else if(lang==="en"){
    btn.innerText="🌐 Translate: EN";
    descText.innerText="PLEASE READ AND UNDERSTAND ALL RULES BEFORE REGISTERING.";
    rulesBtn.innerText="📜 READ THE RULES";
    lblAdmin.innerText="Select Admin";
    lblNama.innerText="Full Name";
    lblUmur.innerText="Age";
    lblAsal.innerText="From";
    lblGroup.innerText="Group Name";
    lblJumlah.innerText="How many people are in the group?";
    lblMember.innerText="Member Names";
    lblLagu.innerText="Song to perform";
    lblLink.innerText="Account Link";
    infoGroup.innerText="(information: if you don't have one, please create a group)";
    lblAgree.innerText="I agree to all rules.";
    btnSubmit.innerText="SEND REGISTRATION VIA WHATSAPP";
  }

  else if(lang==="cn"){
    btn.innerText="🌐 Translate: CN";
    descText.innerText="报名之前请阅读并理解所有规则。";
    rulesBtn.innerText="📜 阅读规则";
    lblAdmin.innerText="选择管理员";
    lblNama.innerText="姓名";
    lblUmur.innerText="年龄";
    lblAsal.innerText="来自";
    lblGroup.innerText="组合名称";
    lblJumlah.innerText="成员人数";
    lblMember.innerText="成员姓名";
    lblLagu.innerText="演唱歌曲";
    lblLink.innerText="账号链接";
    infoGroup.innerText="（如果没有，请创建组合）";
    lblAgree.innerText="我已阅读并同意所有规则。";
    btnSubmit.innerText="通过WhatsApp发送报名";
  }

  else if(lang==="ph"){
    btn.innerText="🌐 Translate: PH";
    descText.innerText="Pakibasa at unawain ang lahat ng patakaran bago mag-register.";
    rulesBtn.innerText="📜 Basahin ang Rules";
    lblAdmin.innerText="Piliin ang Admin";
    lblNama.innerText="Buong Pangalan";
    lblUmur.innerText="Edad";
    lblAsal.innerText="Mula sa";
    lblGroup.innerText="Pangalan ng Grupo";
    lblJumlah.innerText="Ilang miyembro";
    lblMember.innerText="Mga pangalan ng miyembro";
    lblLagu.innerText="Kantang kakantahin";
    lblLink.innerText="Link ng account";
    infoGroup.innerText="(kung wala pa, gumawa ng group)";
    lblAgree.innerText="Sumasang-ayon ako sa lahat ng patakaran.";
    btnSubmit.innerText="IPADALA ANG REGISTRATION VIA WHATSAPP";
  }

  else if(lang==="kr"){
    btn.innerText="🌐 Translate: KR";
    descText.innerText="등록 전에 모든 규칙을 읽고 이해하세요.";
    rulesBtn.innerText="📜 규칙 보기";
    lblAdmin.innerText="관리자 선택";
    lblNama.innerText="이름";
    lblUmur.innerText="나이";
    lblAsal.innerText="출신";
    lblGroup.innerText="그룹 이름";
    lblJumlah.innerText="그룹 인원수";
    lblMember.innerText="멤버 이름";
    lblLagu.innerText="부를 노래";
    lblLink.innerText="계정 링크";
    infoGroup.innerText="(없으면 그룹을 만드세요)";
    lblAgree.innerText="모든 규칙에 동의합니다.";
    btnSubmit.innerText="WhatsApp으로 신청 보내기";
  }
}

// submit WA tetap
document.getElementById("formWalla").addEventListener("submit",function(e){
e.preventDefault();
if(!setuju.checked){alert("Harus setuju dulu!");return;}
let pesan=`Halo Admin, saya ingin mendaftar Singing Event WALLA / HEESAY.\n\nFull Name: ${nama.value}\nAge: ${umur.value}\nFrom: ${asal.value}\nName Group Sing: ${groupname.value}\nTotal Members: ${jumlah.value}\nName Member Group: ${membergroup.value}\nSong: ${lagu.value}\nLink Account: ${link.value}\nLink Group Sing: ${linkgroup.value}`;
window.open("https://wa.me/"+admin.value+"?text="+encodeURIComponent(pesan),"_blank");
});
</script>

</body>
</html>